# Supabase (비즈 전용 프로젝트 — 그래플레이 운영 DB와 분리)
# Supabase 대시보드 > Project Settings > API 에서 확인
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 토스페이먼츠 클라이언트 키 (공개 가능). 미설정 시 토스 공개 테스트 키로 동작.
# 토스 대시보드 > 결제연동 > API 키 에서 확인 (test_ck_... 또는 라이브 키)
VITE_TOSS_CLIENT_KEY=
# (참고) 시크릿 키 TOSS_SECRET_KEY 는 클라이언트에 두지 말 것 — Supabase Edge Function secret으로만 설정
